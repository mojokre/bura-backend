# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Extra Origins (comma-separated), e.g. phone: http://192.168.x.x:3000
CORS_ORIGINS=

# Supabase — paste your project values here
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket that contains profile icons
SUPABASE_STORAGE_BUCKET=profile-images
# Optional prefix inside the bucket (example: "icons/")
SUPABASE_PROFILE_ICONS_PREFIX=
